{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    },
    "outDir": "dist",
    "rootDir": ".."
  },
  "include": ["src/**/*.ts", "../shared/types/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
