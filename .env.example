# IAM-authenticated Lambda Function URL
VITE_BACKEND_URL=https://your-lambda-id.lambda-url.us-east-1.on.aws/

# Cognito Identity Pool for guest credentials (no sign-up required)
VITE_COGNITO_IDENTITY_POOL_ID=us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional override if backend URL region cannot be parsed
# VITE_AWS_REGION=us-east-1

# Optional frontend build label
# VITE_APP_ENV=staging
